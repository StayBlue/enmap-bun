{
  "name": "enmap-bun",
  "version": "6.1.5-bun.0",
  "description": "A Bun-focused fork of Enmap with bun:sqlite persistence and the current TypeScript API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "bunx tsc",
    "dev": "bunx tsc --watch",
    "format": "bunx prettier . --write",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "docs": "bun ./scripts/generate-docs-enhanced.js all",
    "docs:markdown": "bun ./scripts/generate-docs-enhanced.js markdown",
    "docs:typedoc": "bun ./scripts/generate-docs-enhanced.js typedoc",
    "docs:retype": "bun ./scripts/generate-docs-enhanced.js retype",
    "retype": "cd docs && bunx retype build"
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Linux123123/enmap-bun.git"
  },
  "bugs": {
    "url": "https://github.com/Linux123123/enmap-bun/issues"
  },
  "homepage": "https://github.com/Linux123123/enmap-bun#readme",
  "keywords": [
    "sqlite",
    "sql",
    "sqlite3",
    "bun",
    "bun:sqlite",
    "db",
    "database",
    "caching",
    "storing",
    "easy",
    "quick",
    "simple",
    "wrapper"
  ],
  "author": "Eric-Sebastien Lachance <eslachance@gmail.com> (https://alterion.dev/)",
  "license": "Apache-2.0",
  "dependencies": {
    "better-serialize": "^2.0.0",
    "lodash-es": "^4.17.21",
    "on-change": "^5.0.1"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.10.0",
    "bun-types": "^1.3.11",
    "eslint": "^8.41.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-node": "^11.1.0",
    "jsdoc-to-markdown": "^8.0.0",
    "limax": "^4.0.0",
    "prettier": "^3.7.4",
    "retype": "^0.2.0",
    "typedoc": "^0.28.11",
    "typedoc-plugin-markdown": "^4.8.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
